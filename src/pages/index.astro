---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Intro from "../components/Intro.astro";
import About from "../components/About.astro";
import Projects from "../components/Projects.astro";
import Resume from "../components/Resume.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { defaultLang } from "../i18n/config";
import { useTranslations } from "../i18n/utils";
import { getSiteData } from "../i18n/data";

const lang = defaultLang;
const t = useTranslations(lang);
const data = getSiteData(lang);

const baseUrl = "https://alejandro-esteve.com";
const url = `${baseUrl}/`;
const image = `${baseUrl}/images/yo.jpg`;
const locale = "es_ES";
const alternateLocale = "en_US";
const alternateUrl = `${baseUrl}/en/`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${baseUrl}/#person`,
      name: "Alejandro Esteve Maza",
      jobTitle: t("meta.jobTitle"),
      url: baseUrl,
      image,
      sameAs: [
        "https://www.linkedin.com/in/alejandro-esteve-maza/",
        "https://github.com/AlejandroEsteveMaza",
      ],
      knowsAbout: ["React", "Java", "Spring", "AWS", "PostgreSQL", "MySQL"],
    },
    {
      "@type": "WebSite",
      "@id": `${baseUrl}/#website`,
      url: baseUrl,
      name: t("meta.title"),
      description: t("meta.description"),
      inLanguage: ["es", "en"],
      publisher: { "@id": `${baseUrl}/#person` },
    },
    {
      "@type": "WebPage",
      "@id": `${url}#webpage`,
      url,
      name: t("meta.title"),
      description: t("meta.description"),
      inLanguage: lang,
      isPartOf: { "@id": `${baseUrl}/#website` },
      about: { "@id": `${baseUrl}/#person` },
    },
    ...data.projects.items.map((project, index) => ({
      "@type": "CreativeWork",
      "@id": `${url}#project-${index + 1}`,
      name: project.title,
      description: project.description,
      url: `${url}#projects`,
      inLanguage: lang,
      creator: { "@id": `${baseUrl}/#person` },
    })),
  ],
};
---
<BaseLayout
  title={t("meta.title")}
  description={t("meta.description")}
  url={url}
  image={image}
  jsonLd={jsonLd}
  locale={locale}
  alternateLocale={alternateLocale}
  alternateUrl={alternateUrl}
>
  <Header />
  <main>
    <Intro />
    {data.showProjects && <Projects />}
    <Resume />
    <About />
    {data.showContact && <Contact />}
  </main>
  <Footer />
</BaseLayout>
