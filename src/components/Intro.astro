---
import "../styles/intro.css";
import { AmbientParticles } from "./ui/ambient-particles";
import { SkillsMarquee } from "./ui/skills-marquee";
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getSiteData } from '../i18n/data';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const data = getSiteData(lang);
---
<section id="home" class="intro-section">
  <div class="intro-particles" aria-hidden="true">
    <AmbientParticles client:load className="intro-particles-canvas" />
  </div>
  <div class="intro-top">
    <div class="intro-title">
      <div class="intro-status">
        <img
          class="intro-status-avatar"
          src="/images/yo.jpg"
          alt="Portrait of Alejandro Esteve Maza"
          width="1024"
          height="1024"
          loading="eager"
        />
        <a class="intro-status-button" href={data.showContact ? "#contact" : "mailto:alex.esteve98@gmail.com"}>
          {t('intro.cta')}
        </a>
      </div>
      <h1>{t('intro.title')}</h1>
      <p class="intro-p" set:html={t('intro.subtitle')}></p>
      <ul class="intro-ul">
        <li>
          <a
            class="intro-links intro-links-mail"
            href="mailto:alex.esteve98@gmail.com"
            aria-label={t('contact.emailLabel')}
          >
            <i class="bx bx-sm bxs-envelope"></i>
            <span>{t('intro.contactAction')}</span>
          </a>
        </li>
        <li>
          <a
            class="intro-links"
            href="https://www.linkedin.com/in/alejandro-esteve-maza/"
            data-linkedin-app="linkedin://in/alejandro-esteve-maza/"
            data-linkedin-web="https://www.linkedin.com/in/alejandro-esteve-maza/"
            aria-label="LinkedIn"
          >
            <i class="bx bx-sm bxl-linkedin-square"></i>
            <span>LinkedIn</span>
          </a>
        </li>
        <li>
          <a
            class="intro-links"
            href="https://github.com/AlejandroEsteveMaza"
            aria-label="GitHub"
          >
            <i class="bx bx-sm bxl-github"></i>
            <span>GitHub</span>
          </a>
        </li>
      </ul>
    </div>
  </div>
  <div class="intro-skills">
    <div>
      <h3>{t('intro.skillsTitle')}</h3>
    </div>
    <SkillsMarquee />
  </div>
</section>
