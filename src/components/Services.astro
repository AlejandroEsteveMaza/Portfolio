---
import "../styles/services.css";
---

<!-- Suggested meta title (Spanish): "Cómo trabajo con fundadores y empresas no técnicas" -->
<!-- Suggested meta description (Spanish): "Consultoría tecnológica para empresas con diseño de soluciones software, automatización empresarial y validación técnica de ideas para reducir costes y tiempo." -->

<section id="services" class="services" aria-label="Cómo trabajo y servicios">
  <!-- HERO -->
  <header class="services__hero">
    <div class="services__container services__hero-inner">
      <div class="services__hero-content">
        <p class="services__eyebrow">Consultoría tecnológica para empresas</p>
        <h1 class="services__title">
          Cómo trabajo con fundadores y empresas no técnicas
        </h1>
        <p class="services__intro">
          Combino consultoría tecnológica para empresas con diseño de soluciones
          software, automatización empresarial y desarrollo de producto digital
          para reducir riesgos desde el inicio.
        </p>
        <p class="services__intro">
          Aporto validación técnica de ideas para priorizar lo que realmente
          impacta en negocio y operación.
        </p>
        <p class="services__seo-line">
          Los clientes no compran tecnología. Compran claridad y resultados.
        </p>
        <div class="services__hero-actions" aria-label="Acciones principales">
          <a class="services__btn services__btn--primary" href="#contacto">
            Ver cómo trabajo
          </a>
          <a class="services__btn services__btn--secondary" href="/content">
            Leer mis ideas
          </a>
        </div>
      </div>
      <aside class="services__hero-aside" aria-label="Resumen del enfoque">
        <div class="services__aside-card">
          <div class="services__aside-header">
            <svg
              class="services__aside-icon"
              viewBox="0 0 48 48"
              aria-hidden="true"
              focusable="false"
            >
              <circle
                cx="24"
                cy="24"
                r="18"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              />
              <path
                d="M16 24l5 5 11-11"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            <p class="services__aside-title">Resumen rápido</p>
          </div>
          <ul class="services__summary">
            <li>
              <strong>Qué hago:</strong> consultoría tecnológica para empresas
              enfocada en resultados.
            </li>
            <li>
              <strong>Para quién:</strong> fundadores y equipos no técnicos.
            </li>
            <li>
              <strong>Cómo:</strong> diseño de soluciones software,
              automatización empresarial y validación técnica de ideas.
            </li>
            <li>
              <strong>Próximo paso:</strong> una conversación corta para
              alinear prioridades.
            </li>
          </ul>
        </div>
      </aside>
    </div>
  </header>

  <nav class="services__subnav" aria-label="Secciones de servicios">
    <div class="services__container services__subnav-inner">
      <a href="#incluye">Qué incluye</a>
      <a href="#proceso">Proceso</a>
      <a href="#casos">Casos</a>
      <a href="#contacto">Contacto</a>
    </div>
  </nav>

  <!-- INCLUDES -->
  <section id="incluye" class="services__section" aria-labelledby="incluye-title">
    <div class="services__container">
      <div class="services__panel">
        <header class="services__section-header">
          <h2 id="incluye-title">Qué incluye y qué no</h2>
          <p>
            Un marco claro para tomar decisiones de diseño de soluciones
            software y evitar costes innecesarios.
          </p>
        </header>
        <div class="services__columns">
          <article class="services__column">
            <h3>Incluye</h3>
            <ul class="services__list">
              <li>Diagnóstico y priorización con foco en negocio.</li>
              <li>Diseño de soluciones software y roadmap realista.</li>
              <li>Automatización empresarial con impacto medible.</li>
              <li>Desarrollo de producto digital cuando aporta valor.</li>
              <li>Validación técnica de ideas antes de invertir.</li>
            </ul>
          </article>
          <article class="services__column">
            <h3>No incluye</h3>
            <ul class="services__list">
              <li>Proyectos sin objetivos o retorno definido.</li>
              <li>Construcción por moda o complejidad innecesaria.</li>
              <li>Dependencia total sin transferencia de criterio.</li>
              <li>Desarrollo eterno sin medición real.</li>
              <li>Promesas sin validación técnica de ideas.</li>
            </ul>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section id="proceso" class="services__section" aria-labelledby="proceso-title">
    <div class="services__container">
      <div class="services__panel">
        <header class="services__section-header">
          <h2 id="proceso-title">
            Proceso de consultoría tecnológica para empresas
          </h2>
          <p>
            Un paso a paso claro para reducir incertidumbre y mantener el foco
            en impacto.
          </p>
        </header>
        <ol class="services__steps" aria-label="Proceso de trabajo">
          <li>
            <article class="services__step-card">
              <div class="services__step-top">
                <span class="services__badge">01</span>
                <svg
                  class="services__icon"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path
                    d="M12 4v16M4 12h16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                  />
                </svg>
              </div>
              <h3>Diagnóstico</h3>
              <ul class="services__list">
                <li>Entiendo el problema de negocio</li>
                <li>Identifico cuellos de botella</li>
                <li>Evalúo impacto vs complejidad</li>
              </ul>
            </article>
          </li>
          <li>
            <article class="services__step-card">
              <div class="services__step-top">
                <span class="services__badge">02</span>
                <svg
                  class="services__icon"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path
                    d="M4 7h16M4 12h10M4 17h6"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                  />
                </svg>
              </div>
              <h3>Diseño de solución</h3>
              <ul class="services__list">
                <li>Arquitectura conceptual</li>
                <li>Priorización</li>
                <li>Qué NO construir</li>
              </ul>
            </article>
          </li>
          <li>
            <article class="services__step-card">
              <div class="services__step-top">
                <span class="services__badge">03</span>
                <svg
                  class="services__icon"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  focusable="false"
                >
                  <rect
                    x="4"
                    y="5"
                    width="16"
                    height="14"
                    rx="3"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  />
                  <path
                    d="M8 12h8"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                  />
                </svg>
              </div>
              <h3>Automatización</h3>
              <ul class="services__list">
                <li>Reducción de tareas manuales</li>
                <li>Integraciones</li>
                <li>IA aplicada cuando tiene sentido</li>
              </ul>
            </article>
          </li>
          <li>
            <article class="services__step-card">
              <div class="services__step-top">
                <span class="services__badge">04</span>
                <svg
                  class="services__icon"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path
                    d="M5 18h14M7 6h10l2 6H5l2-6z"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linejoin="round"
                  />
                </svg>
              </div>
              <h3>Desarrollo</h3>
              <ul class="services__list">
                <li>Construcción pragmática</li>
                <li>Velocidad sin deuda técnica innecesaria</li>
              </ul>
            </article>
          </li>
          <li>
            <article class="services__step-card">
              <div class="services__step-top">
                <span class="services__badge">05</span>
                <svg
                  class="services__icon"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path
                    d="M12 4v6l4 4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                  />
                  <circle
                    cx="12"
                    cy="12"
                    r="8"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  />
                </svg>
              </div>
              <h3>Iteración y mejora</h3>
              <ul class="services__list">
                <li>Medición</li>
                <li>Ajustes</li>
                <li>Decisiones basadas en uso real</li>
              </ul>
            </article>
          </li>
        </ol>
        <a class="services__link" href="/services">Ver servicios</a>
      </div>
    </div>
  </section>

  <!-- CASES -->
  <section id="casos" class="services__section" aria-labelledby="casos-title">
    <div class="services__container">
      <div class="services__panel">
        <header class="services__section-header">
          <h2 id="casos-title">Casos / ejemplos</h2>
          <p>
            Ejemplos realistas de consultoría tecnológica para empresas y
            automatización empresarial aplicada.
          </p>
        </header>
        <div class="services__cases">
          <article class="services__case-card">
            <span class="services__case-label">Ejemplo</span>
            <h3>Automatización de reporting semanal</h3>
            <ul class="services__case-points">
              <li><strong>Problema:</strong> informes manuales cada semana.</li>
              <li>
                <strong>Solución:</strong> integraciones y tableros
                automatizados.
              </li>
              <li>
                <strong>Resultado:</strong> reportes en minutos y control
                continuo.
              </li>
            </ul>
            <ul class="services__tags">
              <li>Automatización empresarial</li>
              <li>Integraciones</li>
              <li>Reporting</li>
            </ul>
          </article>
          <article class="services__case-card">
            <span class="services__case-label">Ejemplo</span>
            <h3>Validación técnica de idea para marketplace B2B</h3>
            <ul class="services__case-points">
              <li>
                <strong>Problema:</strong> dudas sobre alcance y coste real.
              </li>
              <li>
                <strong>Solución:</strong> diseño de soluciones software y
                pruebas rapidas.
              </li>
              <li>
                <strong>Resultado:</strong> inversión aprobada con roadmap claro.
              </li>
            </ul>
            <ul class="services__tags">
              <li>Validación técnica de ideas</li>
              <li>Producto digital</li>
              <li>Discovery</li>
            </ul>
          </article>
          <article class="services__case-card">
            <span class="services__case-label">Ejemplo</span>
            <h3>Onboarding automatizado para clientes nuevos</h3>
            <ul class="services__case-points">
              <li>
                <strong>Problema:</strong> alta manual y tiempos de espera.
              </li>
              <li>
                <strong>Solución:</strong> flujo guiado con automatización
                empresarial.
              </li>
              <li>
                <strong>Resultado:</strong> reducción de costes y mejor
                experiencia.
              </li>
            </ul>
            <ul class="services__tags">
              <li>Automatización empresarial</li>
              <li>Experiencia de cliente</li>
              <li>Diseño de soluciones software</li>
            </ul>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <footer id="contacto" class="services__cta" aria-labelledby="contacto-title">
    <div class="services__container">
      <div class="services__cta-panel">
        <h2 id="contacto-title">
          Tienes un problema técnico y no sabes por dónde empezar
        </h2>
        <p>Hablemos antes de construir nada.</p>
        <div class="services__cta-actions">
          <a class="services__btn services__btn--primary" href="/contact">
            Contactar
          </a>
          <a class="services__link" href="/content">Ver contenido</a>
        </div>
        <p class="services__microcopy">Respondo en 48h laborables.</p>
      </div>
    </div>
  </footer>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Technology & Product Consultant",
      "serviceType": "Consultoría tecnológica para empresas",
      "description": "Consultoría tecnológica para empresas con diseño de soluciones software, automatización empresarial y desarrollo de producto digital.",
      "areaServed": "ES",
      "url": "/services"
    }
  </script>

</section>
