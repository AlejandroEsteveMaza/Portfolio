---
import "../styles/resume.css";
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getSiteData } from '../i18n/data';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { resume } = getSiteData(lang);
---
<section id="experience" class="Resume-container">
  <div class="Resume-title">
    <h2>{t('resume.title')}</h2>
  </div>
  <ol class="Resume-timeline">
    {resume.items.map((item) => (
      <li class="Resume-item">
        <span class="Resume-dot" aria-hidden="true"></span>
        <article class="Resume-card">
          <p class="Resume-period">{item.period}</p>
          <h3>{item.role}</h3>
          <p class="Resume-company">{item.company}</p>
          <p class="Resume-description">{item.description}</p>
          {item.positions && item.positions.length > 0 && (
            <ul class="Resume-positions">
              {item.positions.map((position) => (
                <li>
                  <p class="Resume-position-role">{position.role}</p>
                  <p class="Resume-position-period">{position.period}</p>
                </li>
              ))}
            </ul>
          )}
        </article>
      </li>
    ))}
  </ol>
</section>
